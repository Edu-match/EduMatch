{
  "framework": "nextjs",
  "regions": ["hnd1"],
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/forum-category-content-sync",
      "schedule": "10 15 * * *"
    },
    {
      "path": "/api/cron/forum-ai-delayed-replies",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/interop-axis-positions",
      "schedule": "20 15 * * *"
    },
    {
      "path": "/api/cron/interop-topic-edges",
      "schedule": "40 15 * * *"
    },
    {
      "path": "/api/cron/interop-axis-config",
      "schedule": "0 16 * * 1"
    }
  ]
}
